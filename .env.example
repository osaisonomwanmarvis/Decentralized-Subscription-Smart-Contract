# ============================================================
# SubscriptionPlatform — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It's already in .gitignore.
# ============================================================

# -----------------------------------------------
# WALLET (Required)
# -----------------------------------------------

# The private key of the wallet that will DEPLOY and OWN the contract.
# This wallet pays deployment gas and controls admin functions.
# For production: use a hardware wallet flow or multi-sig.
# How to export from MetaMask: Account Details → Export Private Key
PRIVATE_KEY=your_private_key_here_do_not_share


# -----------------------------------------------
# RPC PROVIDERS (Required — pick one or both)
# -----------------------------------------------

# Alchemy API Key (recommended)
# Get free key at: https://dashboard.alchemy.com
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Infura API Key (alternative)
# Get free key at: https://infura.io
INFURA_API_KEY=your_infura_api_key_here


# -----------------------------------------------
# CONTRACT SETTINGS (Required)
# -----------------------------------------------

# The ERC20 token address to accept as default payment.
# This must be a valid ERC20 contract on the target network.
#
# Common testnet addresses:
# Sepolia USDC:  0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
# Sepolia WETH:  0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14
#
# Common mainnet addresses:
# USDC:  0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
# USDT:  0xdAC17F958D2ee523a2206206994597C13D831ec7
# WETH:  0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2
DEFAULT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000


# -----------------------------------------------
# VERIFICATION (Recommended)
# -----------------------------------------------

# Etherscan API Key — used to verify contract source code after deployment.
# Verification lets users read your contract on Etherscan.
# Get free key at: https://etherscan.io/register
ETHERSCAN_API_KEY=your_etherscan_api_key_here


# -----------------------------------------------
# NETWORK SELECTION (Optional — defaults shown)
# -----------------------------------------------

# Deployment network. Options: localhost, hardhat, sepolia, mainnet, polygon, arbitrum
# Set via CLI flag: --network sepolia
# NETWORK=sepolia


# -----------------------------------------------
# OPTIONAL OVERRIDES
# -----------------------------------------------

# Override the platform fee at deployment (basis points, default: 500 = 5%)
# Valid range: 0–1000 (0% to 10%)
# PLATFORM_FEE_PERCENT=500

# Grace period in seconds (default: 604800 = 7 days)
# GRACE_PERIOD_SECONDS=604800

# Gas price override in gwei (leave blank to use network estimate)
# GAS_PRICE_GWEI=20

# Report gas usage during tests (true/false)
REPORT_GAS=false


# -----------------------------------------------
# MONITORING (Optional but Recommended)
# -----------------------------------------------

# Tenderly credentials for transaction simulation and alerts
# Get at: https://tenderly.co
# TENDERLY_PROJECT=your-project
# TENDERLY_USERNAME=your-username
# TENDERLY_ACCESS_KEY=your-access-key


# ============================================================
# SECURITY REMINDERS
# ============================================================
# 1. This file (.env) must NEVER be committed to git
# 2. Add .env to your .gitignore (already done in this template)
# 3. For mainnet: use a hardware wallet (Ledger/Trezor) not a hot wallet
# 4. For teams: use a secrets manager (AWS Secrets Manager, Doppler, etc.)
# 5. Rotate keys immediately if you suspect compromise
# ============================================================
